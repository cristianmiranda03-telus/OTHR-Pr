# Copy to .env or set in n8n environment / credentials.
# Do NOT commit real values to version control.

# Telegram Bot (from @BotFather) and target chat/channel ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# FuelXI (or other AI API) for chat completions
FUELXI_API_KEY=your_fuelxi_api_key_here

# Finnhub for economic calendar (free tier: https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_api_key_here
