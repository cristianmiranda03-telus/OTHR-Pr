# --- Option A: paste SSID from browser cookies (no Playwright) ---
# POCKETOPTION_SSID=42["auth",{"session":"..."}]
POCKETOPTION_DEMO=1

# --- Option B: email + password (install: pip install ".[credentials]" && playwright install chromium) ---
# POCKETOPTION_EMAIL=you@example.com
# POCKETOPTION_PASSWORD=your_password

# Optional: show the browser window while logging in (helps with CAPTCHA / 2FA)
# POCKETOPTION_HEADLESS=0

# Optional: override login URL if Pocket Option redirects your locale
# POCKETOPTION_LOGIN_URL=https://pocketoption.com/en/login
